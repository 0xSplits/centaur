# Hoist tslib to the root node_modules. discord.js (used by services/discordbot) ships its source
# directly and requires tslib; with pnpm's strict layout, Bun cannot always resolve the nested
# .pnpm symlink for it ("Cannot find package 'tslib' from .../discord.js/src/index.js"). Public-
# hoisting tslib makes it resolvable from anywhere by walking up to the root node_modules.
public-hoist-pattern[]=tslib
